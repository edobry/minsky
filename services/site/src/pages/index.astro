---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Minsky — the cyberbrain for software organizations";
const description =
  "Minsky is a substrate for AI-assisted software work: orchestrates tasks, sessions, and review across a flock of agents extending a principal's cognition.";
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen flex items-center justify-center px-6 py-24">
    <div class="max-w-3xl w-full">
      <p class="eyebrow mb-6">Minsky · cyberbrain substrate</p>
      <h1
        class="font-sans tracking-display text-[var(--text-display)] leading-[1.05] font-medium mb-8"
        style="color: var(--color-text-primary);"
      >
        The cyberbrain for software organizations led by a principal.
      </h1>
      <p
        class="text-[var(--text-body)] max-w-prose"
        style="color: var(--color-text-muted);"
      >
        Placeholder hero — Phase 1 foundation. Brand tokens applied, SEO scaffold
        live, fonts loaded. Hero copy, product screenshots, and CTAs land in Phase 2.
      </p>
    </div>
  </main>
</BaseLayout>
