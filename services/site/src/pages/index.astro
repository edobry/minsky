---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import CoProductRow from "../components/CoProductRow.astro";
import SubstrateWalkthrough from "../components/SubstrateWalkthrough.astro";
import SiteFooter from "../components/SiteFooter.astro";

const title = "Minsky — the cyberbrain for software organizations";
const description =
  "Minsky orchestrates tasks, sessions, and review across a flock of agents — a substrate that extends one principal's cognition, not a synthetic workforce that replaces your team.";
---

<BaseLayout title={title} description={description}>
  <Header />
  <main>
    <Hero />
    <CoProductRow />
    <SubstrateWalkthrough />
  </main>
  <SiteFooter />
</BaseLayout>
