---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import CoProductRow from "../components/CoProductRow.astro";

const title = "Minsky — the cyberbrain for software organizations";
const description =
  "Minsky orchestrates tasks, sessions, and review across a flock of agents — a substrate that extends a principal's cognition without becoming a team tool.";
---

<BaseLayout title={title} description={description}>
  <Header />
  <main>
    <Hero />
    <CoProductRow />
  </main>
</BaseLayout>
