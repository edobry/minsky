node_modules/
*.log
.env
.env.local
# Local-only run outputs from harness/benchmark scripts (mt#1515).
# Results files are generated by harness runs and meant to be inspected
# locally; they should not be committed (per the README's "Re-running the
# harness" section).
scripts/*-results.json
# Seeded-bug fidelity harness target directory (mt#1515).
# The harness pushes seeded-bug files directly to a remote branch via the
# GitHub git API (createBlob/createTree/createCommit), then closes the PR
# and deletes the branch. Locally this directory is normally empty; the
# ignore prevents accidental commits if a contributor manually checks out
# a seeded branch for inspection.
scripts/__seeded_bug_targets__/
