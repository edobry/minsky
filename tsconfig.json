{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext", "DOM"],
    "target": "ES2022",
    "module": "esnext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "allowImportingTsExtensions": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "typeRoots": ["./node_modules/@types", "./types"],
    "noImplicitAny": false,
    "types": ["bun"]
  },
  "include": ["src", "types", "tests", ".eslintrc.cjs", ".prettierrc.cjs"],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    // "scripts" is a DELIBERATE exclusion, not an oversight: it has its own
    // dedicated tsconfig.scripts.json (mirroring tsconfig.hooks.json's
    // pattern for .claude/hooks) and CI typecheck step, so a script file
    // reachable via import from something under "include" above isn't
    // double-checked here under a different (non-"bun","node") types config.
    // History: mt#3082 fixed 15 known errors and rejected adding this
    // dedicated project in its own scope (a probe surfaced ~180 latent
    // errors across ~43 files, including errors outside scripts/ entirely);
    // mt#3088 paid down that debt and added tsconfig.scripts.json.
    "scripts",
    "src/scripts",
    "src/cockpit/web",
    "tests/fixtures",
    "tests/integration/fixtures"
  ]
}

// Force TS Server to re-evaluate
