{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext", "DOM"],
    "target": "ES2022",
    "module": "esnext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "allowImportingTsExtensions": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "noEmit": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "typeRoots": ["./node_modules/@types", "./types"],
    "noImplicitAny": false,
    "types": ["bun"]
  },
  "include": ["src", "types", "tests", ".eslintrc.cjs", ".prettierrc.cjs"],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    // "scripts" is a DELIBERATE exclusion (mt#3082 decision record), not an
    // oversight: a probe including all of scripts/ in one program surfaced
    // ~180 latent type errors across ~43 files (vs. the 15/3 mt#3082 was
    // scoped to fix), including errors in files OUTSIDE scripts/ entirely.
    // scripts/ relies on its own per-script test suites for correctness for
    // now; see mt#3088 for the tracked follow-up to add dedicated typecheck
    // coverage (tsconfig.scripts.json, mirroring tsconfig.hooks.json's
    // pattern) once that debt is paid down.
    "scripts",
    "src/scripts",
    "src/cockpit/web",
    "tests/fixtures",
    "tests/integration/fixtures"
  ]
}

// Force TS Server to re-evaluate
