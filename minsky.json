{
  "workflows": {
    "lint": {
      "jsonCommand": "./node_modules/.bin/eslint . --format json",
      "fixCommand": "./node_modules/.bin/eslint . --fix"
    },
    "test": {
      "jsonCommand": "bun test --reporter json"
    },
    "format": {
      "jsonCommand": "prettier --check . --list-different"
    }
  }
}
