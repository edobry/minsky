{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|mcp__minsky__session_write_file|mcp__minsky__session_edit_file|mcp__minsky__session_search_replace",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/typecheck-on-edit.sh",
            "timeout": 30,
            "statusMessage": "Type checking...",
            "asyncRewake": true
          }
        ]
      }
    ]
  }
}
