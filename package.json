{
  "name": "minsky",
  "description": "A development workflow orchestration platform that creates collaborative environments for both human and AI developers through organizational cybernetic principles.",
  "icon": "assets/icon/minsky-icon.svg",
  "keywords": [
    "minsky",
    "workflow",
    "orchestration",
    "mcp",
    "model-context-protocol",
    "ai",
    "developer-tools",
    "cybernetics",
    "task-management",
    "session",
    "git",
    "cli"
  ],
  "module": "dist/minsky.js",
  "type": "module",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "start": "bun run src/cli.ts",
    "build": "bun run build:completion-manifest && bun build --target=bun --outdir=dist --entry-naming minsky.js --sourcemap=external src/cli.ts && bun run build:copy-migrations",
    "build:completion-manifest": "bun run scripts/build-completion-manifest.ts",
    "build:copy-migrations": "mkdir -p dist/storage/migrations && rm -rf dist/storage/migrations/pg && cp -r packages/domain/src/storage/migrations/pg dist/storage/migrations/pg",
    "prepublishOnly": "bun run build",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "lint:tests": "bun detect-placeholder-tests.ts",
    "prepare": "husky",
    "postinstall": "bun -e \"try{require('fs').chmodSync('scripts/cli-entry.ts',0o755)}catch{}\"",
    "icons:generate": "bun scripts/generate-icons.ts",
    "format": "prettier --write \"**/*.{ts,js,json,md}\" --log-level silent",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\" --log-level silent",
    "format:all": "bun run format && bun run lint:fix",
    "test": "bun test --preload ./tests/setup.ts --timeout=15000 ./src ./tests/adapters ./tests/domain ./tests/scripts ./packages/shared/src",
    "test:unit": "bun test --preload ./tests/setup.ts --timeout=15000 ./src ./tests/adapters ./tests/domain ./tests/scripts",
    "test:integration": "RUN_INTEGRATION_TESTS=1 bun test --preload ./tests/setup.ts --timeout=30000",
    "test:integration:docker": "RUN_INTEGRATION_TESTS=1 RUN_TESTCONTAINER_TESTS=1 bun test --preload ./tests/setup.ts --timeout=180000 tests/integration/postgres-pool-saturation.testcontainer.integration.test.ts",
    "test:all": "bun test --preload ./tests/setup.ts --timeout=30000",
    "test:watch": "bun test --preload ./tests/setup.ts --watch ./src ./tests/adapters ./tests/domain ./tests/scripts --timeout=15000",
    "test:coverage": "bun test --preload ./tests/setup.ts --coverage ./src ./tests/adapters ./tests/domain ./tests/scripts --timeout=15000",
    "test:quality": "bun tests/utils/test-quality-cli.ts report",
    "test:flaky": "bun tests/utils/test-quality-cli.ts flaky",
    "test:slow": "bun tests/utils/test-quality-cli.ts slow",
    "test:debug": "DEBUG_TESTS=1 bun test --preload ./tests/setup.ts --timeout=15000",
    "test:debug:integration": "DEBUG_TESTS=1 RUN_INTEGRATION_TESTS=1 bun test --preload ./tests/setup.ts --timeout=30000",
    "test:components": "bun test --preload ./tests/dom-setup.ts --preload ./tests/setup.ts --timeout=15000 src/cockpit/web/widgets src/cockpit/web/lib src/cockpit/web/components",
    "test:eslint-rules": "bun test --timeout=15000 eslint-rules/",
    "test:reviewer": "cd services/reviewer && bun run test",
    "validate-commit": "bun scripts/validate-commit-message.ts",
    "smoke:gh-timeout": "bun scripts/smoke-mt2245-github-timeout.ts",
    "smoke:oauth-consent": "bun scripts/smoke-oauth-consent-https.ts",
    "typecheck": "bunx @typescript/native-preview --noEmit",
    "typecheck:hooks": "bunx @typescript/native-preview --noEmit -p tsconfig.hooks.json",
    "validate-all": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run test:eslint-rules",
    "secrets:gitleaks": "gitleaks detect --source . --verbose",
    "secrets:scan": "gitleaks detect --source . --verbose",
    "db:generate:pg": "bunx --yes drizzle-kit generate --config ./drizzle.pg.config.ts",
    "db:generate:reviewer": "cd services/reviewer && bunx --yes drizzle-kit generate --config ./drizzle.pg.config.ts",
    "db:generate:bootstrap-snapshot": "bun scripts/generate-bootstrap-snapshot.ts",
    "db:migrate": "bun src/cli.ts persistence migrate --dry-run",
    "db:migrate:apply": "bun src/cli.ts persistence migrate --execute",
    "cockpit:build": "vite build"
  },
  "bin": {
    "minsky": "./scripts/cli-entry.ts"
  },
  "files": [
    "dist/",
    "!dist/*.map",
    "scripts/cli-entry.ts",
    "package.json",
    "README.md",
    "LICENSE",
    "assets/icon/"
  ],
  "devDependencies": {
    "@eslint/js": "9.29.0",
    "@happy-dom/global-registrator": "^20.9.0",
    "@modelcontextprotocol/inspector": "^0.16.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.2.11",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.17",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@typescript/native-preview": "7.0.0-dev.20260419.1",
    "@valibot/to-json-schema": "^1.3.0",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "bun-types": "latest",
    "effect": "^3.16.12",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.3.4",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.5.3",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "minimatch": "^10.2.5",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "testcontainers": "^10.13.2",
    "ts-morph": "^26.0.0",
    "vite": "^5.4.19"
  },
  "peerDependencies": {
    "typescript": "5.8.3"
  },
  "overrides": {
    "_comment_ansi_regex_strip_ansi": "mt#1892 PR #1155 R1 BLOCKING: @pnpm/tabtab pulls in enquirer@2.4.1 which would downgrade top-level resolutions of ansi-regex (6→5) and strip-ansi (7→6). Pin top-level back to v6/v7; enquirer keeps its own scoped v5/v6 resolution.",
    "ansi-regex": "^6.0.1",
    "strip-ansi": "^7.0.1"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.2",
    "@ai-sdk/google": "^1.0.2",
    "@ai-sdk/openai": "^1.0.2",
    "@clack/prompts": "^0.11.0",
    "@dotenvx/dotenvx": "^1.45.2",
    "@hpcc-js/wasm": "^2.26.1",
    "@minsky/domain": "workspace:*",
    "@minsky/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^22.0.0",
    "@pnpm/tabtab": "^0.5.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.100.10",
    "@types/logform": "^1.10.1",
    "@types/winston": "^2.4.4",
    "@xyflow/react": "^12.11.0",
    "ai": "^4.1.5",
    "braintrust": "^3.10.0",
    "chalk": "^5.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "commander": "^14.0.0",
    "drizzle-kit": "^0.31.2",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.3",
    "gpt-tokenizer": "^3.0.1",
    "gray-matter": "^4.0.3",
    "logform": "^2.7.0",
    "lucide-react": "^1.14.0",
    "oidc-provider": "^9.8.3",
    "postgres": "^3.4.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.1",
    "reactflow": "^11.11.4",
    "reflect-metadata": "^0.2.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tiktoken": "^1.0.22",
    "tsyringe": "^4.10.0",
    "winston": "^3.17.0",
    "yaml": "^2.8.0",
    "zod": "^4.3.6"
  }
}
