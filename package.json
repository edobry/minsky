{
  "name": "minsky",
  "description": "A development workflow orchestration platform that creates collaborative environments for both human and AI developers through organizational cybernetic principles.",
  "keywords": [
    "minsky",
    "workflow",
    "orchestration",
    "mcp",
    "model-context-protocol",
    "ai",
    "developer-tools",
    "cybernetics",
    "task-management",
    "session",
    "git",
    "cli"
  ],
  "module": "src/cli.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/cli.ts",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "lint:tests": "bun detect-placeholder-tests.ts",
    "prepare": "husky",
    "postinstall": "npx skills experimental_install -y",
    "format": "prettier --write \"**/*.{ts,js,json,md}\" --log-level silent",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\" --log-level silent",
    "format:all": "bun run format && bun run lint:fix",
    "test": "bun test --preload ./tests/setup.ts --timeout=15000 ./src ./tests/adapters ./tests/domain",
    "test:unit": "bun test --preload ./tests/setup.ts --timeout=15000 ./src ./tests/adapters ./tests/domain",
    "test:integration": "RUN_INTEGRATION_TESTS=1 bun test --preload ./tests/setup.ts --timeout=30000",
    "test:all": "bun test --preload ./tests/setup.ts --timeout=30000",
    "test:watch": "bun test --preload ./tests/setup.ts --watch ./src ./tests/adapters ./tests/domain --timeout=15000",
    "test:coverage": "bun test --preload ./tests/setup.ts --coverage ./src ./tests/adapters ./tests/domain --timeout=15000",
    "test:quality": "bun tests/utils/test-quality-cli.ts report",
    "test:flaky": "bun tests/utils/test-quality-cli.ts flaky",
    "test:slow": "bun tests/utils/test-quality-cli.ts slow",
    "test:debug": "DEBUG_TESTS=1 bun test --preload ./tests/setup.ts --timeout=15000",
    "test:debug:integration": "DEBUG_TESTS=1 RUN_INTEGRATION_TESTS=1 bun test --preload ./tests/setup.ts --timeout=30000",
    "lint:console": "bun scripts/lint-console-usage.ts",
    "lint:console:strict": "bun scripts/lint-console-usage.ts --fail-on-error",
    "validate-commit": "bun scripts/validate-commit-message.ts",
    "typecheck": "bunx @typescript/native-preview --noEmit",
    "validate-all": "bun run format:check && bun run lint && bun run lint:console:strict && bun run typecheck && bun run test",
    "secrets:gitleaks": "gitleaks detect --source . --verbose",
    "secrets:scan": "gitleaks detect --source . --verbose",
    "db:generate:pg": "bunx --yes drizzle-kit generate --config ./drizzle.pg.config.ts",
    "db:migrate": "bun src/cli.ts sessiondb migrate --dry-run",
    "db:migrate:apply": "bun src/cli.ts sessiondb migrate --execute"
  },
  "bin": {
    "minsky": "./src/cli.ts"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@modelcontextprotocol/inspector": "^0.16.2",
    "@types/bun": "^1.2.11",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.17",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@typescript/native-preview": "^7.0.0-dev.20260419.1",
    "@valibot/to-json-schema": "^1.3.0",
    "bun-types": "latest",
    "effect": "^3.16.12",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.3.4",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "minimatch": "^10.2.5",
    "prettier": "^3.5.3",
    "ts-morph": "^26.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.2",
    "@ai-sdk/google": "^1.0.2",
    "@ai-sdk/openai": "^1.0.2",
    "@clack/prompts": "^0.11.0",
    "@dotenvx/dotenvx": "^1.45.2",
    "@hpcc-js/wasm": "^2.26.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^22.0.0",
    "@types/logform": "^1.10.1",
    "@types/winston": "^2.4.4",
    "ai": "^4.1.5",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "drizzle-kit": "^0.31.2",
    "drizzle-orm": "^0.44.2",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.3",
    "gpt-tokenizer": "^3.0.1",
    "gray-matter": "^4.0.3",
    "logform": "^2.7.0",
    "postgres": "^3.4.8",
    "reflect-metadata": "^0.2.2",
    "tiktoken": "^1.0.22",
    "tsyringe": "^4.10.0",
    "winston": "^3.17.0",
    "yaml": "^2.8.0",
    "zod": "^4.3.6"
  }
}
